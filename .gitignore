# ============================================================
# .gitignore
# Files and folders that should NEVER be committed to GitHub
# ============================================================

# Environment variable files — contain API keys and passwords!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Node modules — reinstall with npm install
node_modules/
*/node_modules/

# React build output
frontend/build/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

.vercel
.env*.local

.env
