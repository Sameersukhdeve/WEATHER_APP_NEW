# ============================================================
# WEATHER APP - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file and rename it to .env
# Then fill in your actual values below
# NEVER commit your real .env file to GitHub!
# ============================================================

# --- SERVER ---
PORT=5000

# --- MySQL DATABASE ---
# These are the settings for your MySQL database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=weather_app_db
DB_PORT=3306

# --- OPENWEATHERMAP API ---
# Sign up free at: https://openweathermap.org/api
# Then go to "My API Keys" and copy your key here
OPENWEATHER_API_KEY=your_api_key_here

# --- YOUTUBE DATA API v3 (Optional) ---
# Get from: https://console.cloud.google.com/
# Enable "YouTube Data API v3" and create credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# --- GOOGLE MAPS (Optional) ---
# Get from: https://console.cloud.google.com/
# Enable "Maps Embed API" and create credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- FRONTEND URL (for CORS) ---
FRONTEND_URL=http://localhost:3000
