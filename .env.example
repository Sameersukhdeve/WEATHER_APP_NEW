# ============================================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env in the frontend/ folder.
# IMPORTANT: In React, ALL env variable names MUST start with
# REACT_APP_ or React will ignore them for security reasons.
# ============================================================

# Google Maps API key (optional - app uses OpenStreetMap if blank)
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

